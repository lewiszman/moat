# Copy to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ── Supabase (required) ─────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Build base path (set automatically by CI — do not set locally) ──
# VITE_BASE=/moat/staging/   ← injected by GitHub Actions for staging builds
# Leave unset locally — defaults to /moat/ (production path)
